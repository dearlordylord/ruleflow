{
  "name": "osr-hellenvald",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "effect-language-service patch && husky",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests && jscpd src",
    "lint:fix": "eslint src tests --fix",
    "format": "eslint src tests --fix --rule '@effect/dprint: error'",
    "check-format": "eslint src tests --rule '@effect/dprint: error'",
    "circular": "madge --extensions ts --circular src",
    "check-all": "pnpm typecheck && pnpm lint && pnpm circular && pnpm test",
    "dashboard": "tsx --tsconfig src/dashboard/tsconfig.json src/dashboard/index.tsx",
    "demo:transcript": "tsx examples/transcript-demo.ts"
  },
  "lint-staged": {
    "*.ts": "eslint --fix",
    "*.tsx": "eslint --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@total-typescript/ts-reset": "^0.6.1",
    "effect": "^3.19.15",
    "ink": "^6.6.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.72.0",
    "@effect/vitest": "^0.27.0",
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.3",
    "@types/react": "^19.2.13",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-functional": "^9.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sort-destructure-keys": "^2.0.0",
    "fast-check": "^4.5.3",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  }
}
